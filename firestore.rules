rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function email() {
      return isSignedIn() && request.auth.token.email != null
        ? request.auth.token.email.lower()
        : "";
    }

    // Keep this list aligned with deployed CAPTAIN_EMAILS.
    function isCaptain() {
      return email() in [
        "kaufmann.andreas@live.de"
      ];
    }

    // Public read, Captain write collections
    match /seasons/{id} {
      allow read: if true;
      allow create, update: if isCaptain();
      // Season deletion is server-only via callable integrity checks.
      allow delete: if false;
    }

    match /events/{id} {
      allow read: if true;
      allow create, update, delete: if isCaptain();
    }

    match /attendance/{id} {
      allow read: if true;
      allow create, update, delete: if isCaptain();
    }

    match /players/{id} {
      allow read: if true;
      allow create, update, delete: if isCaptain();
    }

    match /spirit/{id} {
      allow read: if true;
      allow create, update, delete: if isCaptain();
    }

    match /settings/{id} {
      allow read: if true;
      allow create, update, delete: if isCaptain();
    }

    // Notification-related collections
    match /push_tokens/{id} {
      // Subscribers can register/unregister tokens; no public reads.
      allow read: if false;
      allow create, update, delete: if isSignedIn();
    }

    match /notification_log/{id} {
      // Maintained by backend with Admin SDK; deny client access.
      allow read, write: if false;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
